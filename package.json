{
  "name": "dep-version-checker",
  "displayName": "Dependency Version Checker",
  "description": "Tüm proje türlerinde (npm, pip, Cargo, Composer) bağımlılıkların güncel versiyonlarını gösterir; major/minor/patch ayrımı yapar ve tekil ya da toplu günceller.",
  "version": "0.1.0",
  "publisher": "your-publisher-id",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "dependencies",
    "npm",
    "outdated",
    "update",
    "version",
    "semver",
    "pip",
    "cargo",
    "composer"
  ],
  "galleryBanner": {
    "color": "#171327",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KULLANICI_ADIN/dep-version-checker"
  },
  "bugs": {
    "url": "https://github.com/KULLANICI_ADIN/dep-version-checker/issues"
  },
  "homepage": "https://github.com/KULLANICI_ADIN/dep-version-checker#readme",
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:**/package.json",
    "workspaceContains:**/requirements.txt",
    "workspaceContains:**/pyproject.toml",
    "workspaceContains:**/Cargo.toml",
    "workspaceContains:**/composer.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "depCheckerContainer",
          "title": "Dependencies",
          "icon": "resources/dep-icon.svg"
        }
      ]
    },
    "views": {
      "depCheckerContainer": [
        {
          "id": "depCheckerView",
          "name": "Bağımlılıklar",
          "type": "webview",
          "icon": "resources/dep-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "depChecker.refresh",
        "title": "Bağımlılıkları Yeniden Tara",
        "category": "Dep Checker",
        "icon": "$(refresh)"
      },
      {
        "command": "depChecker.updateAll",
        "title": "Tümünü Güncelle",
        "category": "Dep Checker",
        "icon": "$(arrow-up)"
      },
      {
        "command": "depChecker.updateDependency",
        "title": "En Son Sürüme Güncelle",
        "category": "Dep Checker",
        "icon": "$(cloud-download)"
      },
      {
        "command": "depChecker.updateToVersion",
        "title": "Sürüm Seçerek Güncelle",
        "category": "Dep Checker",
        "icon": "$(versions)"
      },
      {
        "command": "depChecker.openInManifest",
        "title": "Manifest'te Aç",
        "category": "Dep Checker",
        "icon": "$(go-to-file)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "depChecker.refresh",
          "when": "view == depCheckerView",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "Dependency Version Checker",
      "properties": {
        "depChecker.includePrerelease": {
          "type": "boolean",
          "default": false,
          "description": "Önizleme (alpha/beta/rc) sürümlerini de güncelleme adayı olarak değerlendir."
        },
        "depChecker.runInstallAfterUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Güncelleme sonrası ilgili paket yöneticisi kurulum komutunu entegre terminalde çalıştır."
        },
        "depChecker.requestTimeoutMs": {
          "type": "number",
          "default": 8000,
          "description": "Registry isteklerinin zaman aşımı (ms)."
        },
        "depChecker.npmPeerConflictStrategy": {
          "type": "string",
          "enum": ["default", "legacy-peer-deps", "force"],
          "enumDescriptions": [
            "Ek bayrak yok (varsayılan npm davranışı).",
            "npm install --legacy-peer-deps (peer dependency çakışmalarını yok say).",
            "npm install --force (çakışmaları zorla geç, riskli)."
          ],
          "default": "default",
          "description": "npm güncellemesinde peer dependency çakışması yaşandığında install komutuna eklenecek strateji."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "npx --yes @vscode/vsce package",
    "publish": "npx --yes @vscode/vsce publish",
    "publish:ovsx": "npx --yes ovsx publish"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
